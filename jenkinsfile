pipeline {
  agent any

  parameters {
    choice(
      name: 'ACTION',
      choices: ['apply', 'destroy'],
      description: 'Terraform action'
    )
  }

  triggers {
    pollSCM('H/5 * * * *')
  }

  environment {
    TF_DIR = 'terraform'
    APP_DIR = 'app'
    AWS_REGION = 'eu-west-2'

    SLACKCHANNEL = 'varsitix'
    SLACKCREDENTIALS = credentials('slack-cred')

    TERRAFORM_VERSION = '1.15.6'
  }

  stages {

    // =========================
    // CHECKOUT
    // =========================
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    // =========================
    // IAC SECURITY SCAN (FIXED)
    // =========================
    stage('IAC Scan (Checkov)') {
      steps {
        sh '''
          set -e

          echo "Installing Checkov..."
          python3 -m pip install --upgrade pip
          python3 -m pip install checkov

          echo "Running Checkov..."
          checkov -d . -o cli --quiet > checkov-results.txt || true
        '''
      }
    }

    // =========================
    // INSTALL TERRAFORM (FIXED - NO sudo, NO PATH ISSUES)
    // =========================
    stage('Install Terraform') {
      steps {
        script {
          sh '''
            set -e

            OS=$(uname -s | tr '[:upper:]' '[:lower:]')
            ARCH=$(uname -m)

            if [ "$ARCH" = "x86_64" ]; then
              ARCH=amd64
            elif [ "$ARCH" = "aarch64" ]; then
              ARCH=arm64
            fi

            echo "Installing Terraform ${TERRAFORM_VERSION}"

            curl -fsSL \
              https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_${OS}_${ARCH}.zip \
              -o terraform.zip

            unzip -o terraform.zip
            chmod +x terraform

            mkdir -p $WORKSPACE/tools
            mv terraform $WORKSPACE/tools/

            echo "Terraform installed in workspace"
          '''

          // ✅ IMPORTANT: persist PATH for ALL stages
          env.PATH = "${env.WORKSPACE}/tools:${env.PATH}"

          sh 'terraform version'
        }
      }
    }

    // =========================
    // TERRAFORM INIT
    // =========================
    stage('Terraform Init') {
      steps {
        dir(TF_DIR) {
          sh '''
            set -e
            terraform init -input=false
          '''
        }
      }
    }

    // =========================
    // TERRAFORM PLAN
    // =========================
    stage('Terraform Plan') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        dir(TF_DIR) {
          sh 'terraform plan -input=false'
        }
      }
    }

    // =========================
    // TERRAFORM APPLY
    // =========================
    stage('Terraform Apply') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        dir(TF_DIR) {
          sh 'terraform apply -auto-approve -input=false'
        }
      }
    }

    // =========================
    // CLONE + BUILD + PUSH DOCKER IMAGE
    // =========================
    stage('Build & Push Docker Image') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        script {

          def ecr = sh(
            script: "cd ${TF_DIR} && terraform output -raw ecr_repository_url",
            returnStdout: true
          ).trim()

          env.ECR_URL = ecr

          sh """
            set -e

            echo "Cloning Next-Hamster repo..."
            rm -rf Next-Hamster
            git clone --depth 1 https://github.com/Level-p/Next-Hamster.git

            cd Next-Hamster

            echo "Logging into ECR..."
            aws ecr get-login-password --region ${AWS_REGION} \
              | docker login --username AWS --password-stdin ${ecr}

            echo "Building Docker image..."
            docker build -t ${ecr}:latest .

            echo "Pushing Docker image..."
            docker push ${ecr}:latest
          """
        }
      }
    }

    // =========================
    // TRIVY SCAN
    // =========================
    stage('Trivy Scan') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        sh '''
          set -e
          trivy image -f table ${ECR_URL}:latest > trivyfs.txt || true
        '''
      }
    }

    // =========================
    // DEPLOY TO ECS
    // =========================
    stage('Deploy to ECS') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        script {

          def cluster = sh(
            script: "cd ${TF_DIR} && terraform output -raw ecs_cluster_name",
            returnStdout: true
          ).trim()

          def service = sh(
            script: "cd ${TF_DIR} && terraform output -raw ecs_service_name",
            returnStdout: true
          ).trim()

          sh """
            set -e

            echo "Deploying to ECS..."
            aws ecs update-service \
              --cluster ${cluster} \
              --service ${service} \
              --force-new-deployment \
              --region ${AWS_REGION}
          """
        }
      }
    }

    // =========================
    // DESTROY
    // =========================
    stage('Terraform Destroy') {
      when {
        expression { params.ACTION == 'destroy' }
      }
      steps {
        dir(TF_DIR) {
          sh 'terraform destroy -auto-approve -input=false'
        }
      }
    }
  }

  // =========================
  // POST ACTIONS
  // =========================
  post {
    always {
      slackSend(
        channel: SLACKCHANNEL,
        color: currentBuild.result == 'SUCCESS' ? 'good' : 'danger',
        message: "Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' finished with status: ${currentBuild.result}. ${env.BUILD_URL}"
      )
    }

    success {
      echo "Pipeline SUCCESS"
    }

    failure {
      echo "Pipeline FAILED"
    }
  }
}