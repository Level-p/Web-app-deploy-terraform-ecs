pipeline {
  agent any

  parameters {
    choice(
      name: 'ACTION',
      choices: ['apply', 'destroy'],
      description: 'Terraform action'
    )
  }

  triggers {
    pollSCM('H/5 * * * *')
  }

  environment {
    TF_DIR = 'terraform'
    APP_DIR = 'app'
    AWS_REGION = 'eu-west-2'

    SLACKCHANNEL = 'varsitix'
    SLACKCREDENTIALS = credentials('slack-cred')

    TERRAFORM_VERSION = '1.15.6'
  }

  stages {

    // =========================
    // CHECKOUT
    // =========================
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    // =========================
    // IAC SECURITY SCAN (CHECKOV FIXED)
    // =========================
    stage('IAC Scan') {
      steps {
        script {
          sh '''
            set -e

            echo "Installing Checkov..."
            python3 -m pip install --upgrade pip
            python3 -m pip install checkov

            echo "Running Checkov scan..."
            checkov -d . -o cli --quiet > checkov-results.txt || true

            echo "Checkov scan completed"
          '''
        }
      }
    }

    // =========================
    // INSTALL TERRAFORM (FIXED FOR 1.15.6)
    // =========================
    stage('Install Terraform') {
      steps {
        sh '''
          set -e

          TERRAFORM_VERSION=1.15.6
          OS=$(uname -s | tr '[:upper:]' '[:lower:]')
          ARCH=$(uname -m)

          if [ "$ARCH" = "x86_64" ]; then
            ARCH="amd64"
          elif [ "$ARCH" = "aarch64" ]; then
            ARCH="arm64"
          else
            echo "Unsupported architecture: $ARCH"
            exit 1
          fi

          echo "Installing Terraform ${TERRAFORM_VERSION} for ${OS}_${ARCH}"

          curl -fsSL \
            https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_${OS}_${ARCH}.zip \
            -o terraform.zip

          unzip -o terraform.zip

          chmod +x terraform
          
          mkdir -p $WORKSPACE/tools
          mv terraform $WORKSPACE/tools/

          env.PATH = "${env.WORKSPACE}/tools:${env.PATH}"
          terraform version
        '''
      }
    }

    // =========================
    // TERRAFORM INIT
    // =========================
    stage('Terraform Init') {
      steps {
        dir(TF_DIR) {
          sh 'terraform init -input=false'
        }
      }
    }

    // =========================
    // TERRAFORM PLAN
    // =========================
    stage('Terraform Plan') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        dir(TF_DIR) {
          sh 'terraform plan -input=false'
        }
      }
    }

    // =========================
    // APPLY INFRA
    // =========================
    stage('Terraform Apply (Infra)') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        dir(TF_DIR) {
          sh 'terraform apply -auto-approve -input=false'
        }
      }
    }

 // =========================
// CLONE & BUILD DOCKER IMAGE
// =========================
stage('Build Docker Image') {
  when {
    expression { params.ACTION == 'apply' }
  }

  steps {
    script {

      // Get ECR URL from Terraform
      def ecr = sh(
        script: "cd ${TF_DIR} && terraform output -raw ecr_repository_url",
        returnStdout: true
      ).trim()

      env.ECR_URL = ecr

      sh """
        set -e

        echo "Cloning Next-Hamster repo..."

        git clone https://github.com/Level-p/Next-Hamster.git

        cd Next-Hamster

        echo "Logging into ECR..."
        aws ecr get-login-password --region ${AWS_REGION} \
          | docker login --username AWS --password-stdin ${ecr}

        echo "Building Docker image..."
        docker build -t ${ecr}:latest .

        echo "Pushing Docker image..."
        docker push ${ecr}:latest

        rm -rf Next-Hamster
      """
    }
  }
}

    // =========================
    // TRIVY SCAN (FIXED PATH)
    // =========================
    stage('Trivy Image Scan') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        sh '''
          set -e
          trivy image -f table ${ECR_URL}:latest > trivyfs.txt || true
        '''
      }
    }

    // =========================
    // DEPLOY TO ECS
    // =========================
    stage('Deploy to ECS') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        script {
          def cluster = sh(
            script: "cd ${TF_DIR} && terraform output -raw ecs_cluster_name",
            returnStdout: true
          ).trim()

          def service = sh(
            script: "cd ${TF_DIR} && terraform output -raw ecs_service_name",
            returnStdout: true
          ).trim()

          sh """
            set -e

            echo "Deploying to ECS cluster: ${cluster}"
            echo "Service: ${service}"

            aws ecs update-service \
              --cluster ${cluster} \
              --service ${service} \
              --force-new-deployment \
              --region ${AWS_REGION}
          """
        }
      }
    }

    // =========================
    // DESTROY INFRA
    // =========================
    stage('Terraform Destroy') {
      when {
        expression { params.ACTION == 'destroy' }
      }
      steps {
        dir(TF_DIR) {
          sh 'terraform destroy -auto-approve -input=false'
        }
      }
    }
  }

  // =========================
  // POST ACTIONS (SLACK)
  // =========================
  post {
    always {
      slackSend(
        channel: SLACKCHANNEL,
        color: currentBuild.result == 'SUCCESS' ? 'good' : 'danger',
        message: "Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' finished with status: ${currentBuild.result}. ${env.BUILD_URL}"
      )
    }

    success {
      echo "Pipeline SUCCESS (ACTION=${params.ACTION})"
    }

    failure {
      echo "Pipeline FAILED (ACTION=${params.ACTION})"
    }
  }
}